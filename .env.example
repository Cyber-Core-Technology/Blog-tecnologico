# =============================================================================
#  CyCoTech Blog — plantilla de variables de entorno
#  Copia este archivo a `.env` y rellena los valores reales.
#  NUNCA versiones el archivo `.env` con secretos.
# =============================================================================

# --- Django core ---------------------------------------------------------
# Genera una clave con:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=changeme-genera-una-clave-larga-y-aleatoria
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False

# Hosts permitidos (separados por coma). Dominio que sirve NPM.
DJANGO_ALLOWED_HOSTS=blog.cyco.tech
# Orígenes confiables para CSRF (con esquema https://)
DJANGO_CSRF_TRUSTED_ORIGINS=https://blog.cyco.tech
# URL base pública (emails, sitemap, opengraph, hostname del Site de Wagtail)
WAGTAIL_BASE_URL=https://blog.cyco.tech

# --- PostgreSQL ----------------------------------------------------------
POSTGRES_DB=blog
POSTGRES_USER=blog
POSTGRES_PASSWORD=changeme-password-postgres-fuerte
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---------------------------------------------------------------
REDIS_PASSWORD=changeme-password-redis-fuerte
# Construida internamente como redis://:PASSWORD@redis:6379/0

# --- AWS S3 (media files) ------------------------------------------------
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
AWS_STORAGE_BUCKET_NAME=mi-blog-media
AWS_S3_REGION_NAME=us-east-1
# Opcional: dominio CDN/custom delante del bucket (sin esquema). Vacío = S3 default.
AWS_S3_CUSTOM_DOMAIN=

# --- Email / SMTP (newsletter + transaccional) ---------------------------
EMAIL_HOST=smtp.tuproveedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=changeme
EMAIL_HOST_PASSWORD=changeme
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=CyCoTech Blog <no-reply@cyco.tech>

# --- Traducción automática (DeepL) ---------------------------------------
# Crea una cuenta gratis en https://www.deepl.com/pro-api y copia tu clave.
# Las claves gratuitas terminan en ":fx". Sin clave, la traducción es manual.
DEEPL_API_KEY=

# --- Seguridad (HSTS) ----------------------------------------------------
# 0 mientras pruebas; 31536000 (1 año) cuando el HTTPS sea estable.
DJANGO_SECURE_HSTS_SECONDS=0

# --- Superusuario inicial (opcional, para bootstrap automatizado) --------
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@cyco.tech
# DJANGO_SUPERUSER_PASSWORD=changeme
